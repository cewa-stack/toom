# ============================================
# APLIKACJA - USTAWIENIA OGÓLNE
# ============================================
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ============================================
# MARKETPLACE - WYBÓR AKTYWNEGO PLUGINU
# ============================================
# Nazwa musi odpowiadać nazwie folderu w infrastructure/plugins/
MARKETPLACE_PROVIDER=allegro

# ============================================
# ALLEGRO - OAuth2 + PKCE
# ============================================
ALLEGRO_CLIENT_ID=twoj_client_id
ALLEGRO_CLIENT_SECRET=twoj_client_secret
ALLEGRO_ENVIRONMENT=production
# Adres przekierowania musi być zarejestrowany dokładnie tak w panelu Allegro
ALLEGRO_REDIRECT_URI=http://localhost:53682/auth/callback
ALLEGRO_TOKEN_ENCRYPTION_KEY=wygeneruj_losowy_klucz_32_bajty

# ============================================
# TELEGRAM (bot: TOOM)
# ============================================
TELEGRAM_BOT_TOKEN=twoj_token_bota
TELEGRAM_ADMIN_CHAT_ID=123456789

# ============================================
# BAZA DANYCH
# ============================================
DATABASE_URL=sqlite+aiosqlite:///./data/toom.db
DATABASE_ECHO=false

# ============================================
# SCHEDULER
# ============================================
SYNC_ORDERS_INTERVAL_SECONDS=60
# Przypomnienie o niewysłanych zamówieniach (20:00) oraz nocne czyszczenie
# czatu (02:00) mają stałe godziny czasu Europe/Warsaw - nie wymagają zmiennych.

# ============================================
# SMS (powiadomienie klienta przy pakowaniu)
# ============================================
# Dostawca bramki SMS. "logging" = tryb testowy (loguje treść zamiast
# realnej wysyłki). Realną bramkę podłącza się nową implementacją
# SmsProvider i zmianą tej wartości (np. na "smsapi").
SMS_PROVIDER=logging
# Nazwa nadawcy widoczna na SMS u realnego operatora.
SMS_SENDER_NAME=TOOM

# ============================================
# BACKUP
# ============================================
BACKUP_DIRECTORY=./backups
BACKUP_RETENTION_DAYS=30

# ============================================
# LOGOWANIE
# ============================================
LOG_DIRECTORY=./logs
LOG_ROTATION=10 MB
LOG_RETENTION_DAYS=14

# ============================================
# TOOM API (aplikacja mobilna TOOM Mobile)
# ============================================
# Token używany przez aplikację mobilną (nagłówek
# "Authorization: Bearer <token>"). Wygeneruj losowy ciąg, np.:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
TOOM_API_TOKEN=wygeneruj_losowy_token
# 0.0.0.0 = nasłuch na wszystkich interfejsach (wymagane, aby telefon
# połączył się przez Tailscale/LAN - patrz docs/01_app.md, sekcja 4).
TOOM_API_HOST=0.0.0.0
TOOM_API_PORT=8000
# Opcjonalne: ścieżka do zbudowanej wersji TOOM Mobile
# (`npx expo export -p web` w mobile/) - gdy ustawiona, backend serwuje
# całą aplikację pod `/` (ten sam port co API). Puste = backend serwuje
# wyłącznie API, tak jak dotychczas. Patrz docs/01_app.md §6.5.
WEB_APP_DIST_PATH=

# ============================================
# WEB PUSH (drugi kanał powiadomień - TOOM Mobile jako PWA, patrz
# docs/01_app.md sekcja Web Push - myślany głównie pod iPhone'a, gdzie
# natywny push wymaga płatnego konta Apple Developer)
# ============================================
# Puste wartości = Web Push wyłączony (jedynym kanałem zostaje Telegram).
# Wygeneruj parę kluczy poleceniem:
# uv run python -c "
# from py_vapid import Vapid02
# import base64
# v = Vapid02(); v.generate_keys()
# priv = v.private_key.private_numbers().private_value.to_bytes(32, 'big')
# print('VAPID_PRIVATE_KEY=' + base64.urlsafe_b64encode(priv).decode().rstrip('='))
# from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat
# pub = v.public_key.public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)
# print('VAPID_PUBLIC_KEY=' + base64.urlsafe_b64encode(pub).decode().rstrip('='))
# "
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Adres kontaktowy wymagany przez specyfikację VAPID (nie musi być realną skrzynką).
VAPID_CLAIM_EMAIL=mailto:admin@example.com
